#!/bin/sh
# runs whenever lazyvim extras or lockfile changes
# lazyvim.json: {{ include "private_dot_config/nvim/lazyvim.json" | sha256sum }}
# lazy-lock.json: {{ include "private_dot_config/nvim/lazy-lock.json" | sha256sum }}
set -eu

# Ensure brew is on PATH (Linux)
if [ "$(uname -s)" = "Linux" ] && [ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

nvim --headless "+Lazy! sync" +qa
